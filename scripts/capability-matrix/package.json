{
  "name": "@supabase/capability-matrix-validator",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Validator for the Supabase SDK capability matrix.",
  "scripts": {
    "validate": "tsx src/cli.ts validate",
    "validate:online": "tsx src/cli.ts validate --online",
    "report": "tsx src/cli.ts report",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
